generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("user") // user | admin
  canCreate    Boolean  @default(true) // 加题权限，管理员可关闭
  direction    String? // 用户方向，如「前端」
  shareCode    String?  @unique // 8 位分享码
  shareCodeSetAt DateTime @default(now()) // 重置时间
  createdAt    DateTime @default(now())

  questions         Question[] // 我创建/拥有的题
  topics            Topic[] // 我的话题树（私人）
  practiceRecords   PracticeRecord[]
  interviewSessions InterviewSession[]
  likes             QuestionLike[]
  views             QuestionView[]
  testPapers        TestPaper[]
  testPaperAttempts TestPaperAttempt[]
  syncsFrom         SyncRecord[] @relation("SyncFrom")
  syncsTo           SyncRecord[] @relation("SyncTo")
}

// 私人话题树：每个用户一棵，根节点 parentId 为 null，可任意嵌套。
// 方向不进树（方向是用户个人属性），树里全是话题，如「分布式」「AI面试 → RAG系统」。
model Topic {
  id        String   @id @default(cuid())
  userId    String // 归属用户
  parentId  String? // 父话题，根节点为 null
  name      String
  visibility String   @default("private") // private | public | force_off
  sortOrder Int      @default(0) // 同级排序
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Topic?     @relation("TopicChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Topic[]    @relation("TopicChildren")
  questions Question[]

  @@index([userId])
  @@index([parentId])
}

model Question {
  id              String    @id @default(cuid())
  ownerId         String // 创建者/拥有者
  topicId         String? // 所属话题节点，null = 未分类（拉取来的副本默认未分类）
  direction       String // 方向，如「前端」——供题库广场跨用户筛选
  difficulty      String // 简单 / 中等 / 困难
  title           String
  body            String     @db.Text
  referenceAnswer String     @db.Text
  detailedAnswer  String     @db.Text // 详细答案：可能包含落地/扩展细节，应用层插入时给空串
  answerGeneratedByAi Boolean @default(false) // 参考答案由 AI 补全 → 显示「🤖 AI 生成答案」徽章
  importedByAi        Boolean @default(false) // 整题来自「导入题目」流水线，便于批量筛选核对
  tags            String     @db.Text // 逗号分隔
  visibility      String    @default("private") // private | public
  forceHidden     Boolean   @default(false) // 父目录公开但此题强制隐藏
  isDelisted      Boolean   @default(false) // 管理员下架
  deletedAt       DateTime? // 软删除标记
  // 热度分量（分开存，便于改权重）
  manualHeat      Int       @default(0)
  viewCount       Int       @default(0)
  likeCount       Int       @default(0)
  cloneCount      Int       @default(0)
  sourceId        String? // 克隆来源题 id
  createdAt       DateTime  @default(now())

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  topic           Topic?           @relation(fields: [topicId], references: [id], onDelete: SetNull)
  practiceRecords PracticeRecord[]
  likes           QuestionLike[]
  views           QuestionView[]
  testPaperItems  TestPaperItem[]

  @@index([ownerId])
  @@index([topicId])
  @@index([visibility, isDelisted])
}

model QuestionLike {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([questionId])
}

model QuestionView {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([questionId])
}

model PracticeRecord {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  userAnswer String @db.Text
  aiFeedback String @db.Text
  score      Int      @default(0)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model InterviewSession {
  id        String   @id @default(cuid())
  userId    String
  role      String // 目标岗位，如「前端工程师」
  level     String // 初级 / 中级 / 高级
  status    String   @default("active") // active / finished
  summary   String   @db.Text
  score     Int      @default(0)
  createdAt DateTime @default(now())

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages InterviewMessage[]

  @@index([userId])
}

model InterviewMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String // interviewer / candidate
  content   String   @db.Text
  createdAt DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model AiModelConfig {
  id          String    @id @default(cuid())
  role        String // primary | answer | vision
  name        String
  baseUrl     String
  model       String
  apiKey      String
  enabled     Boolean   @default(true)
  isDefault   Boolean   @default(false)
  sortOrder   Int       @default(0)
  lastErrorAt DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([role])
  @@index([role, enabled])
  @@index([role, isDefault])
  @@index([role, sortOrder])
}

model AiPromptConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String   @default("")
  category    String
  content     String   @db.Text
  variables   String   @db.Text // 应用层写入默认 "[]"
  enabled     Boolean  @default(true)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([enabled])
}

model TestPaper {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String   @db.Text
  timeLimit   Int? // 考试时间限制（分钟），null 表示不限时
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    TestPaperItem[]
  attempts TestPaperAttempt[]

  @@index([userId])
}

model TestPaperItem {
  id         String @id @default(cuid())
  paperId    String
  questionId String
  sortOrder  Int    @default(0)

  paper    TestPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([questionId])
}

model TestPaperAttempt {
  id         String    @id @default(cuid())
  paperId    String
  userId     String
  answers    String    @db.Text // JSON: { questionId: answerText }，应用层写入默认 "{}"
  scores     String    @db.Text // JSON: { questionId: score }，应用层写入默认 "{}"
  feedbacks  String    @db.Text // JSON: { questionId: feedback }，应用层写入默认 "{}"
  totalScore Int       @default(0)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  paper TestPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([userId])
  @@index([paperId, userId])
}

model SyncRecord {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  scope       String // all | topic | paper
  scopeRefId  String? // topic 或 paper 的 id（scope=all 时为 null）
  status      String   @default("pending") // pending | running | done | failed
  error       String?  @db.Text // 失败原因
  createdCount Int    @default(0) // 新建题数
  skippedCount Int    @default(0) // 跳过题数
  newTopicCount Int   @default(0)
  newPaperCount Int   @default(0)
  createdAt   DateTime @default(now())
  finishedAt  DateTime? // 完成时间

  fromUser User @relation("SyncFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("SyncTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, createdAt])
  @@index([fromUserId])
}
