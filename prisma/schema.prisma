generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("user") // user | admin
  canCreate    Boolean  @default(true) // 加题权限，管理员可关闭
  direction    String? // 用户方向，如「前端」
  createdAt    DateTime @default(now())

  questions         Question[] // 我创建/拥有的题
  topics            Topic[] // 我的话题树（私人）
  practiceRecords   PracticeRecord[]
  interviewSessions InterviewSession[]
  likes             QuestionLike[]
  views             QuestionView[]
}

// 私人话题树：每个用户一棵，根节点 parentId 为 null，可任意嵌套。
// 方向不进树（方向是用户个人属性），树里全是话题，如「分布式」「AI面试 → RAG系统」。
model Topic {
  id        String   @id @default(cuid())
  userId    String // 归属用户
  parentId  String? // 父话题，根节点为 null
  name      String
  sortOrder Int      @default(0) // 同级排序
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Topic?     @relation("TopicChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Topic[]    @relation("TopicChildren")
  questions Question[]

  @@index([userId])
  @@index([parentId])
}

model Question {
  id              String    @id @default(cuid())
  ownerId         String // 创建者/拥有者
  topicId         String? // 所属话题节点，null = 未分类（拉取来的副本默认未分类）
  direction       String // 方向，如「前端」——供题库广场跨用户筛选
  difficulty      String // 简单 / 中等 / 困难
  title           String
  body            String
  referenceAnswer String
  answerGeneratedByAi Boolean @default(false) // 参考答案由 AI 补全 → 显示「🤖 AI 生成答案」徽章
  importedByAi        Boolean @default(false) // 整题来自「导入题目」流水线，便于批量筛选核对
  tags            String // 逗号分隔
  visibility      String    @default("private") // private | public
  isDelisted      Boolean   @default(false) // 管理员下架
  deletedAt       DateTime? // 软删除标记
  // 热度分量（分开存，便于改权重）
  manualHeat      Int       @default(0)
  viewCount       Int       @default(0)
  likeCount       Int       @default(0)
  cloneCount      Int       @default(0)
  sourceId        String? // 克隆来源题 id
  createdAt       DateTime  @default(now())

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  topic           Topic?           @relation(fields: [topicId], references: [id], onDelete: SetNull)
  practiceRecords PracticeRecord[]
  likes           QuestionLike[]
  views           QuestionView[]

  @@index([ownerId])
  @@index([topicId])
  @@index([visibility, isDelisted])
}

model QuestionLike {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([questionId])
}

model QuestionView {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([questionId])
}

model PracticeRecord {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  userAnswer String
  aiFeedback String
  score      Int      @default(0)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model InterviewSession {
  id        String   @id @default(cuid())
  userId    String
  role      String // 目标岗位，如「前端工程师」
  level     String // 初级 / 中级 / 高级
  status    String   @default("active") // active / finished
  summary   String   @default("")
  score     Int      @default(0)
  createdAt DateTime @default(now())

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages InterviewMessage[]

  @@index([userId])
}

model InterviewMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String // interviewer / candidate
  content   String
  createdAt DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
