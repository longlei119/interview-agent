# DeepSeek 大模型 API 配置
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 视觉识别模型（「导入题目」从图片识别题目用，可选）
# 不配置则图片导入不可用，但粘贴文本导入仍可用。
# api_key/base_url 留空会回落到上面的主模型；model 必须填才算配置可用。
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=

# 答案生成模型（给没有答案的导入题自动补参考答案，可选）
# 三项都留空则回落到主模型 deepseek-chat；想换更强模型时填这三项。
ANSWER_API_KEY=
ANSWER_BASE_URL=
ANSWER_MODEL=

# JWT 签名密钥（请改成一段随机长字符串）
JWT_SECRET=please-change-me-to-a-long-random-string

# 第一个管理员邮箱：用该邮箱注册的账号自动成为管理员。
# 注册后也可随时用 `npm run set-admin <email>` 把已有账号提升为管理员。
ADMIN_EMAIL=admin@example.com

# 数据库（SQLite，开发用）
DATABASE_URL="file:./dev.db"
